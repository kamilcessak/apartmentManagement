# MongoDB connection (Docker Compose default):
# ATLAS_URI=mongodb://admin:password@mongodb:27017
ATLAS_URI=

# Required — signing access tokens. Rotate periodically in production: issue new tokens
# after changing this value (existing JWTs become invalid immediately).
JWT_SECRET=

PORT=5050

# Used in invitation and verification emails (must match the SPA origin for links).
FRONTEND_URL=http://localhost:5173

# Optional — comma-separated list of allowed browser origins for CORS.
# If unset, defaults to FRONTEND_URL + local Vite URLs (5173).
# CORS_ORIGINS=http://localhost:5173,https://app.example.com

EMAIL_HOST=
EMAIL_PORT=
EMAIL_SECURE=
EMAIL_USER=
EMAIL_PASS=
